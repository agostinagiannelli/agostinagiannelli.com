---
import { Image } from "astro:assets";
import Badge from "@/components/Badge.astro";
import SocialLink from "@/components/SocialLink.astro";
import LinkedInIcon from "@/assets/icons/LinkedIn.astro";
import GitHubIcon from "@/assets/icons/GitHub.astro";
import MailIcon from "@/assets/icons/Mail.astro";
import DownloadIcon from "@/assets/icons/Download.astro";
---

<div class="max-w-3xl mb-24">
  <div class="flex gap-4 mb-4">
    <Image
      class="rounded-full shadow-lg dark:border dark:border-slate-600"
      src="/agostinagiannelli.webp"
      alt="Agostina Giannelli"
      width="92"
      height="92"
      loading="eager"
    />
    <Badge href="https://linkedin.com/in/agostinagiannelli"
      >Let's connect! 🚀</Badge
    >
  </div>
  <h1
    class="text-3xl font-bold text-black lg:text-4xl xl:text-5xl lg:tracking-tight xl:tracking-tighter dark:text-white"
  >
    Hey, I'm Agostina • Growth & Experimentation Strategist
  </h1>
  <div
    class="mt-6 space-y-4 text-lg tracking-tight text-slate-800 dark:text-slate-200"
  >
    <p>
      Helping digital businesses grow through experimentation, data-driven
      optimisation and user behaviour insights, with 11+ years of experience in
      ecommerce. Building AI-powered workflows for CRO, analytics and
      experimentation.
    </p>
    <p>Fluent in Spanish & English • Based in Madrid, Spain 🇪🇸</p>
  </div>
  <div class="flex flex-wrap gap-3 mt-8">
    <SocialLink
      href="https://drive.google.com/file/d/1xcLrF940HZc57k09nAWWZ5OEOg0Zk9yg/view"
    >
      <DownloadIcon class="size-4" />
      Download CV
    </SocialLink>
    <SocialLink href="mailto:agostinagiannelli@gmail.com">
      <MailIcon class="size-4" />
      Email
    </SocialLink>
    <SocialLink href="https://linkedin.com/in/agostinagiannelli">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialLink>
    <SocialLink href="https://github.com/agostinagiannelli">
      <GitHubIcon class="size-4" />
      GitHub
    </SocialLink>
  </div>
</div>
