---
import Heading2 from "@/components/Heading2.astro";
import RobotIcon from "@/assets/icons/Robot.astro";
import PipeIcon from "@/assets/icons/Pipe.astro";
import EyeIcon from "@/assets/icons/Eye.astro";
import ChartIcon from "@/assets/icons/Chart.astro";
import Pill from "./Pill.astro";

const SKILLS = [
  {
    title: "Experimentation & CRO Strategy",
    description:
      "Designing experimentation roadmaps, prioritising hypotheses and validating growth opportunities through A/B testing and personalisation strategies.",
    icon: PipeIcon,
  },
  {
    title: "Behavioural Insights",
    description:
      "Identifying friction, cognitive load and behavioural barriers across digital journeys to improve user decision-making and enable more effective personalisation and conversion.",
    icon: EyeIcon,
  },
  {
    title: "Digital Analytics & Growth Insights",
    description:
      "Using tools such as Adobe Analytics and GA4 to uncover behavioural patterns, measure experimentation impact and guide optimisation decisions.",
    icon: ChartIcon,
  },
  {
    title: "AI-Powered Growth Workflows",
    description:
      "Using custom AI agents to accelerate experimentation workflows, generate hypothesis ideas, analyse behavioural patterns and support data-driven optimisation decisions.",
    icon: RobotIcon,
  },
];

const INDUSTRIES = [
  "Hospitality & Travel",
  "Energy",
  "Banking",
  "Beauty & Cosmetics",
  "Publishing & Education",
];
---

<div>
  <Heading2
    h2="Skills & Expertise"
    paragraph="Combining experimentation, behavioural insights and analytics to drive measurable digital growth across industries including:"
  />
  <div class="flex flex-wrap gap-2 mb-12 md:gap-4 mt-4">
    {INDUSTRIES.map((content) => <Pill content={content} />)}
  </div>
  <div class="grid gap-12 mt-16 sm:grid-cols-2 md:gap-16">
    {
      SKILLS.map(({ title, description, icon: Icon }) => (
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 p-1 mt-1 transition rounded-full bg-slate-800 shrink-0 dark:bg-white md:hover:scale-105">
            <Icon class="text-white p-0.5 dark:text-black" />
          </div>
          <div>
            <h3 class="text-lg font-semibold tracking-tight text-black dark:text-white">
              {title}
            </h3>
            <p class="mt-2 text-slate-600 dark:text-slate-200">{description}</p>
          </div>
        </div>
      ))
    }
  </div>
</div>
