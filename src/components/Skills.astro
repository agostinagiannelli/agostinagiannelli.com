---
import Heading2 from "@/components/Heading2.astro";
import PipeIcon from "@/assets/icons/Pipe.astro";
import SearchIcon from "@/assets/icons/Search.astro";
import GearIcon from "@/assets/icons/Gear.astro";
import CodeIcon from "@/assets/icons/Code.astro";

const SKILLS = [
  {
    title: "CRO Strategy & Execution",
    description:
      "Identifying growth opportunities, building hypotheses and validating them through experimentation.",
    icon: PipeIcon,
  },
  {
    title: "Data Analysis & Insights",
    description:
      "Using Adobe Analytics and GA4 to uncover behavioural insights and guide optimisation decisions.",
    icon: SearchIcon,
  },
  {
    title: "Cross-Functional Collaboration",
    description:
      "Working with product, UX, development and business teams to drive aligned growth initiatives.",
    icon: GearIcon,
  },
  {
    title: "Technical & Business Alignment",
    description:
      "Frontend development and GTM implementation to support experimentation and CRO initiatives.",
    icon: CodeIcon,
  },
];
---

<div>
  <Heading2
    h2="Skills & Expertise"
    paragraph="Combining experimentation, data analysis and technical expertise to drive measurable growth."
  />
  <div class="grid gap-12 mt-16 sm:grid-cols-2 md:gap-16">
    {
      SKILLS.map(({ title, description, icon: Icon }) => (
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 p-1 mt-1 transition rounded-full bg-slate-800 shrink-0 dark:bg-white md:hover:scale-105">
            <Icon class="text-white p-0.5 dark:text-black" />
          </div>
          <div>
            <h3 class="text-lg font-semibold tracking-tight text-black dark:text-white">
              {title}
            </h3>
            <p class="mt-2 text-slate-600 dark:text-slate-200">{description}</p>
          </div>
        </div>
      ))
    }
  </div>
</div>
