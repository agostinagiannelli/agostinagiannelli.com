---
const { content } = Astro.props;
---

<div class="flex items-center transition md:justify-center md:hover:scale-105">
  <div
    class="inline-flex items-center justify-center w-full px-3 py-1 text-xs font-semibold text-purple-400 uppercase bg-purple-100 rounded-full outline outline-1 dark:bg-slate-800 dark:text-slate-200 whitespace-nowrap"
  >
    {content}
  </div>
</div>
