---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/Container.astro";
import Hero from "@/components/Hero.astro";
import Skills from "@/components/Skills.astro";
import Block from "@/components/Block.astro";
import Logos from "@/components/Logos.astro";
import FadedLine from "@/components/FadedLine.astro";
---

<Layout
  title="Agostina Giannelli - Growth & CRO"
  description="Growth and CRO specialist focused on experimentation, behavioural insights and data-driven optimisation. Leveraging AI-assisted workflows to drive digital growth."
  url="https://agostinagiannelli.com"
>
  <Container>
    <Hero />
    <FadedLine />
    <Skills />
    <Logos />
    <Block
      h2="Thanks for dropping by!"
      paragraph="Interested in discussing experimentation, CRO or digital growth?"
      href="/contact"
      text="Get in Touch"
    />
  </Container>
</Layout>
